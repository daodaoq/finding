# ============================================================
# Finding 大学生社交平台 - 生产环境变量
# 复制为 .env 后修改实际值（密码务必修改！）
# ============================================================

# ---- Docker 中间件密码 ----
MYSQL_ROOT_PASSWORD=Finding@2026
REDIS_PASSWORD=Finding@2026
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=Finding@2026
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=Finding@2026

# ---- Spring Boot 后端 ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=finding
MYSQL_USER=root
MYSQL_PASSWORD=Finding@2026

REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=finding

# 生产环境激活
SPRING_PROFILES_ACTIVE=prod

# JWT 密钥（生产环境务必替换为随机字符串！）
# 生成方式: openssl rand -base64 64
JWT_ACCESS_SECRET=your-access-secret-at-least-256-bits-long-please-change-this
JWT_REFRESH_SECRET=your-refresh-secret-at-least-256-bits-long-please-change-this
